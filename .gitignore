# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
*.tmp

# local debug / scratch files
tmp_*.js

ROADMAP.md
GEMINI.md

# generated bundles
node_test_bundle*.js
node_test_bundle*.cjs

# local tool state
/.gemini/

# root-level scratch / artifact files
/*.txt
/*.js
/*.cjs
/*.gb
!/roms/**/*.gb

